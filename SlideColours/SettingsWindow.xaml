<Window x:Class="SlideColours.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Slide Colours — Settings"
        Width="420" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Segoe UI" FontSize="12">

    <StackPanel Margin="16">

        <GroupBox Header="ProPresenter" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Host:"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="HostBox" Margin="0,2" VerticalContentAlignment="Center"/>

                <Label Grid.Row="1" Grid.Column="0" Content="Port:"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="PortBox" Margin="0,2" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="4,6,0,0" Foreground="Gray" TextWrapping="Wrap"
                           Text="In ProPresenter: Preferences → Network → Enable Network. Use the port shown there."/>
            </Grid>
        </GroupBox>

        <GroupBox Header="DMX output" Padding="8" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Protocol:"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ProtocolBox" Margin="0,2"
                          SelectionChanged="ProtocolBox_SelectionChanged">
                    <ComboBoxItem Tag="artnet" Content="Art-Net (network)"/>
                    <ComboBoxItem Tag="sacn" Content="sACN / E1.31 (network)"/>
                    <ComboBoxItem Tag="enttec" Content="Enttec DMX USB Pro (serial)"/>
                </ComboBox>

                <Label Grid.Row="1" Grid.Column="0" Content="Target IP:" x:Name="TargetIpLabel"/>
                <DockPanel Grid.Row="1" Grid.Column="1" x:Name="TargetIpPanel">
                    <Button DockPanel.Dock="Right" x:Name="ScanButton" Content="Scan…" Width="64" Margin="6,2,0,2"
                            Click="Scan_Click"
                            ToolTip="Search the network for DMX nodes (Art-Net discovery)"/>
                    <TextBox x:Name="TargetIpBox" Margin="0,2" VerticalContentAlignment="Center"
                             ToolTip="Leave blank to broadcast (Art-Net) or multicast (sACN)"/>
                </DockPanel>

                <Label Grid.Row="2" Grid.Column="0" Content="Universe:" x:Name="UniverseLabel"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="UniverseBox" Margin="0,2" VerticalContentAlignment="Center"
                         ToolTip="Art-Net universes start at 0, sACN universes start at 1"/>

                <Label Grid.Row="3" Grid.Column="0" Content="COM port:" x:Name="ComPortLabel"/>
                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="ComPortBox" Margin="0,2" IsEditable="True"/>

                <Label Grid.Row="4" Grid.Column="0" Content="Start channel:"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="StartChannelBox" Margin="0,2" VerticalContentAlignment="Center"
                         ToolTip="First DMX channel of your fixture (1–512). Red, green and blue follow in order."/>

                <CheckBox Grid.Row="5" Grid.ColumnSpan="2" x:Name="DimmerCheck" Margin="4,8,0,2"
                          Content="Fixture has a master dimmer channel before red/green/blue"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Colour behaviour" Padding="8" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Fade time (ms):"/>
                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" x:Name="FadeBox" Margin="0,2" VerticalContentAlignment="Center"/>

                <Label Grid.Row="1" Grid.Column="0" Content="Brightness:"/>
                <Slider Grid.Row="1" Grid.Column="1" x:Name="BrightnessSlider" Minimum="0" Maximum="100"
                        VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>
                <TextBlock Grid.Row="1" Grid.Column="2" x:Name="BrightnessValue" VerticalAlignment="Center" TextAlignment="Right"/>

                <Label Grid.Row="2" Grid.Column="0" Content="Saturation boost:"/>
                <Slider Grid.Row="2" Grid.Column="1" x:Name="SaturationSlider" Minimum="0" Maximum="100"
                        VerticalAlignment="Center" ValueChanged="Slider_ValueChanged"/>
                <TextBlock Grid.Row="2" Grid.Column="2" x:Name="SaturationValue" VerticalAlignment="Center" TextAlignment="Right"/>

                <CheckBox Grid.Row="3" Grid.ColumnSpan="3" x:Name="FullBrightnessCheck" Margin="4,8,0,2"
                          Content="Always output colours at full intensity (recommended for stage wash)"/>

                <Label Grid.Row="4" Grid.Column="0" Content="Colourless slides:"/>
                <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" x:Name="FallbackBox" Margin="0,2"
                          ToolTip="What to do when a slide is black &amp; white with no dominant colour">
                    <ComboBoxItem Tag="keep" Content="Keep the last colour"/>
                    <ComboBoxItem Tag="off" Content="Fade lights to off"/>
                    <ComboBoxItem Tag="white" Content="Fade to warm white"/>
                </ComboBox>
            </Grid>
        </GroupBox>

        <GroupBox Header="Updates" Padding="8" Margin="0,10,0,0">
            <StackPanel>
                <TextBlock x:Name="VersionText" Foreground="Gray" Margin="4,0,0,0"/>
                <TextBlock x:Name="UpdateStatusText" Margin="4,6,0,0" TextWrapping="Wrap"
                           Visibility="Collapsed"/>
                <DockPanel Margin="0,8,0,0">
                    <Button DockPanel.Dock="Left" x:Name="CheckUpdateButton" Content="Check for updates"
                            Padding="10,5" Click="CheckUpdate_Click"/>
                    <Button HorizontalAlignment="Right" x:Name="InstallUpdateButton" Content="Install update"
                            Padding="10,5" Visibility="Collapsed" Click="InstallUpdate_Click"/>
                </DockPanel>
            </StackPanel>
        </GroupBox>

        <CheckBox x:Name="StartEnabledCheck" Margin="4,12,0,0"
                  Content="Turn lighting control on when the app starts"/>

        <DockPanel Margin="0,16,0,0">
            <Button DockPanel.Dock="Left" Content="Test DMX" Width="90" Padding="0,5" Click="Test_Click"
                    ToolTip="Saves these settings, then runs an 8-second colour sweep on the lights"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Padding="0,5" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="Save" Width="80" Padding="0,5" IsDefault="True" Click="Save_Click"/>
            </StackPanel>
        </DockPanel>

    </StackPanel>
</Window>
