<Window x:Class="SlideColours.DiscoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DMX nodes found"
        Width="440" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Segoe UI" FontSize="12">

    <StackPanel Margin="14">
        <TextBlock Text="Select the DMX node to send to:" Margin="0,0,0,8"/>
        <ListBox x:Name="NodesList" MinHeight="80" MaxHeight="220"
                 MouseDoubleClick="NodesList_MouseDoubleClick"/>
        <DockPanel Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Left" Text="Cancel keeps broadcasting to all nodes."
                       Foreground="Gray" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Padding="0,5" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="Use" Width="80" Padding="0,5" IsDefault="True" Click="Use_Click"/>
            </StackPanel>
        </DockPanel>
    </StackPanel>
</Window>
