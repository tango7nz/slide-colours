<Window x:Class="SlideColours.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Slide Colours" Icon="appicon.ico"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize" SizeToContent="WidthAndHeight"
        ShowInTaskbar="True" WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="23" Background="#F0202028" Padding="14,10"
            BorderBrush="#40FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <!-- close the app -->
            <Button x:Name="CloseButton" Style="{StaticResource IconButton}"
                    Content="&#xE8BB;" FontSize="13" VerticalAlignment="Center" Margin="0,0,2,0"
                    Click="Close_Click" ToolTip="Close Slide Colours"/>

            <!-- settings (with an "update available" dot) -->
            <Grid VerticalAlignment="Center" Margin="0,0,4,0">
                <Button x:Name="SettingsButton" Style="{StaticResource IconButton}"
                        Content="&#xE713;" VerticalAlignment="Center"
                        Click="Settings_Click" ToolTip="Settings"/>
                <Ellipse x:Name="UpdateBadge" Width="9" Height="9"
                         HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,1,1,0"
                         Fill="#FF3A6FF0" Stroke="#F0202028" StrokeThickness="1.5"
                         Visibility="Collapsed" IsHitTestVisible="False"
                         ToolTip="An update is available — open Settings to install"/>
            </Grid>

            <!-- favourite colours -->
            <WrapPanel x:Name="FavouritePanel" VerticalAlignment="Center"
                       MaxWidth="220" Margin="8,0,0,0"/>

            <!-- colour mode: follow the live slide (disabled when ProPresenter isn't connected) -->
            <Button x:Name="FollowSlideButton" Style="{StaticResource ModeButton}"
                    Content="Follow slide" VerticalAlignment="Center" Margin="8,0,0,0"
                    Click="FollowSlide_Click" ToolTipService.ShowOnDisabled="True"
                    ToolTip="Match the stage colour to the live slide"/>

            <TextBlock Text="Output:" Foreground="#FFB8B8C0"
                       FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                       Margin="12,0,8,0" VerticalAlignment="Center"/>

            <!-- on/off toggle -->
            <CheckBox x:Name="EnableToggle" Style="{StaticResource ToggleSwitch}"
                      VerticalAlignment="Center"
                      Checked="EnableToggle_Changed" Unchecked="EnableToggle_Changed"
                      ToolTip="Send colour to the stage lights"/>

            <!-- current output colour (far right) -->
            <Ellipse x:Name="ColourSwatch" Width="26" Height="26" Margin="10,0,0,0"
                     Fill="#FF000000" Stroke="#80FFFFFF" StrokeThickness="1.5"
                     VerticalAlignment="Center" Opacity="0.35"
                     ToolTip="Current output colour"/>
        </StackPanel>
    </Border>
</Window>
